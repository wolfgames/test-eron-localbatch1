{
  "name": "example-with-tailwindcss",
  "type": "module",
  "scripts": {
    "predev": "bun run cortex:setup",
    "dev": "vite",
    "build": "vite build",
    "build:qa": "vite build --mode qa",
    "preview": "vite preview",
    "format": "biome check --write .",
    "format:src": "biome check --write ./src",
    "evaluate": "bun run tests/evaluation/run.ts",
    "evaluate:report": "bun run tests/evaluation/compare.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "amino:sync": "bun run scripts/amino-sync.ts",
    "amino:release": "bun run scripts/amino-release.ts",
    "amino:verify": "bun run scripts/amino-verify.ts",
    "amino:rollback": "bun run scripts/amino-rollback.ts",
    "amino:drift": "bun run scripts/amino-drift.ts",
    "check:assets": "bun run scripts/check-asset-naming.ts",
    "check:manifest": "bun run scripts/check-manifest.ts",
    "typecheck": "tsc --noEmit",
    "lint:unused": "knip",
    "cortex:setup": "node node_modules/@wolfgames/cortex/scripts/setup.mjs",
    "cortex:refresh": "bun update @wolfgames/cortex",
    "postinstall": "node node_modules/@wolfgames/cortex/scripts/setup.mjs"
  },
  "cortex": {
    "profile": "default"
  },
  "dependencies": {
    "@adobe/data": "^0.9.45",
    "@sentry/solid": "^10.38.0",
    "@wolfgames/components": "^0.1.20",
    "@wolfgames/cortex": "latest",
    "@wolfgames/game-kit": "^0.0.46",
    "arktype": "^2.1.27",
    "gsap": "^3.14.2",
    "howler": "^2.2.4",
    "pixi.js": "^8.15.0",
    "posthog-js": "^1.331.1",
    "solid-js": "^1.9.5",
    "tweakpane": "^4.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.7",
    "@types/howler": "^2.2.12",
    "@wolfgames/semantic-router": "^0.1.2",
    "@xenova/transformers": "^2.17.2",
    "knip": "^6.0.5",
    "qrcode-terminal": "^0.12.0",
    "tailwindcss": "^4.0.7",
    "vite": "^6.1.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.0"
  },
  "amino": {
    "version": "1.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
